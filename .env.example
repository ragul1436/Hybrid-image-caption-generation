# Database Configuration
# Change the password to something strong before deploying
DB_PASSWORD=change_me_to_a_strong_password

# These will be overridden by docker-compose, but set here for reference
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db:5432/caption_db

# Security - Generate a strong secret key using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_to_a_strong_random_key_minimum_32_chars

# Token Configuration (in minutes/days)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated for production)
# Update these to your actual domain names
BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ML Model Configuration
DEFAULT_MODEL=blip

# SMTP Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
